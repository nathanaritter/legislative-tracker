# Copy to .env for local development. Never commit the real .env.

# Storage toggle
USE_AZURE=false

# Azure (used when USE_AZURE=true, and by the ingest clients regardless)
AZURE_STORAGE_ACCOUNT=stdp58902
AZURE_CONTAINER=etl
KEY_VAULT_NAME=kv-data-registry-dev

# Logging
LOG_LEVEL=INFO

# LegiScan API key is pulled from Key Vault secret LEGISCAN-API-KEY by default.
# Set LEGISCAN_API_KEY here only for local testing without az login.
# LEGISCAN_API_KEY=
